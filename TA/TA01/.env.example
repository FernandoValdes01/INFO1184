# Neon / PostgreSQL connection string.
# Use either NEON_DATABASE_URL or DATABASE_URL.
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Raw schema where the TA01 source tables will be created and loaded.
# Keep this aligned with the schema configured in dbt / Lightdash.
TA01_PG_SCHEMA=public
